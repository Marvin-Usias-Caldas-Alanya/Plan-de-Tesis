# =============================================================================
# Variables de entorno — NutriStore (Vite)
# =============================================================================
# Copia este archivo a .env para desarrollo local:
#   cp .env.example .env
#
# En Vercel: Project → Settings → Environment Variables
#   Añade las mismas variables en Production (y Preview si aplica).
# =============================================================================

# URL del proyecto Supabase (Settings → API → Project URL)
VITE_SUPABASE_URL=https://xxxxxxxx.supabase.co

# Clave pública anon (Settings → API → anon public)
# NUNCA uses service_role en el frontend ni en variables VITE_*
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.ejemplo

# =============================================================================
# Después del despliegue en Vercel, configura también en Supabase:
# Authentication → URL Configuration
#   - Site URL: https://tu-proyecto.vercel.app
#   - Redirect URLs: https://tu-proyecto.vercel.app/**
# =============================================================================
